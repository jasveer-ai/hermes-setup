# Hermes Agent — Environment Variables
# Copy to ~/.hermes/.env and fill in your API keys.
# Required: at least one LLM provider key.

# ── LLM Providers ──────────────────────────
# OpenRouter (recommended — 200+ models, one key)
# Get at: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# Alternative providers (uncomment if needed)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# NVIDIA_API_KEY=
# NOUS_API_KEY=
# XIAOMI_API_KEY=

# ── Messaging Platforms ────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
WHATSAPP_ALLOWED_USERS=

# ── BlueBubbles iMessage Gateway ────────────
BLUEBUBBLES_SERVER_URL=http://localhost:1234
BLUEBUBBLES_PASSWORD=your_bluebubbles_password
BLUEBUBBLES_WEBHOOK_HOST=::
# Remove GATEWAY_ALLOW_ALL_USERS=true once you've set platform allowlists below
# GATEWAY_ALLOW_ALL_USERS=true

# ── Platform Allowlists ────────────────────
# Comma-separated IDs of allowed users per platform
# Find your Telegram ID by messaging @userinfobot
# TELEGRAM_ALLOWED_USERS=your_telegram_id
# BLUEBUBBLES_ALLOWED_USERS=your_icloud_email

# ── Optional Tools ─────────────────────────
# FAL_KEY=                     # Image generation
# BROWSERBASE_API_KEY=         # Browser automation
# BROWSERBASE_PROJECT_ID=      # Browser automation
# EXA_API_KEY=                 # Web search
# FIRECRAWL_API_KEY=           # Web crawl
# HONCHO_API_KEY=              # Cross-session user modeling
# GROQ_API_KEY=                # Fast STT
# VOICE_TOOLS_OPENAI_KEY=      # Voice transcription & TTS

# ── Terminal Backend ───────────────────────
# TERMINAL_CWD=.               # Working directory
# TERMINAL_TIMEOUT=60          # Command timeout (seconds)
# TERMINAL_LIFETIME_SECONDS=300
